#!/usr/bin/env python3
"""Watch xfce4-screensaver and launch mathlock when it activates.

Subscribes to `org.xfce.ScreenSaver.ActiveChanged` on the user's session bus.
When the screensaver activates, launches the mathlock locker as a subprocess.
Subsequent activations while a locker is still running are ignored.
"""
import os
import subprocess

import gi
gi.require_version("Gio", "2.0")
from gi.repository import Gio, GLib


LOCKER = os.path.expanduser("~/.local/bin/mathlock")

_lock_proc = None


def _on_signal(_connection, _sender, _object_path, _interface, _signal, parameters):
    global _lock_proc
    active = parameters.unpack()[0]
    if not active:
        return
    if _lock_proc and _lock_proc.poll() is None:
        return
    _lock_proc = subprocess.Popen([LOCKER])


def main():
    bus = Gio.bus_get_sync(Gio.BusType.SESSION, None)
    bus.signal_subscribe(
        None,
        "org.xfce.ScreenSaver",
        "ActiveChanged",
        None,
        None,
        Gio.DBusSignalFlags.NONE,
        _on_signal,
    )
    GLib.MainLoop().run()


if __name__ == "__main__":
    main()
